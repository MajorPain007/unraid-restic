<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN [
<!ENTITY name      "restic-backup">
<!ENTITY author    "MajorPain007">
<!ENTITY version   "2026.04.18.10">
<!ENTITY md5       "caadb7a4d9a08966c11686e9e5ff959e">
<!ENTITY launch    "Settings/ResticBackup">
<!ENTITY github    "MajorPain007/unraid-restic">
<!ENTITY pluginURL "https://raw.githubusercontent.com/&github;/main/src/&name;.plg">
<!ENTITY pkgURL    "https://raw.githubusercontent.com/&github;/main/archive">
<!ENTITY pluginDir "/usr/local/emhttp/plugins/&name;">
<!ENTITY configDir "/boot/config/plugins/&name;">
<!ENTITY tmpDir    "/tmp/&name;">
<!ENTITY resticVer "0.18.1">
<!ENTITY resticURL "https://github.com/restic/restic/releases/download/v&resticVer;/restic_&resticVer;_linux_amd64.bz2">
<!ENTITY resticSumsURL "https://github.com/restic/restic/releases/download/v&resticVer;/SHA256SUMS">
]>

<PLUGIN name="&name;" author="&author;" version="&version;" launch="&launch;"
        pluginURL="&pluginURL;"
        min="6.12.0"
        icon="shield">

<CHANGES>
## Version 2026.04.18.10
- Scheduled backups now actually fire. The previous version wrote cron
  entries to /etc/cron.d/restic-backup, which Unraid's dcron does not
  reload automatically — so the configured schedule had no effect.
  The plugin now uses the Unraid convention: it writes the entries to
  /boot/config/plugins/restic-backup/restic-backup.cron (no user
  column) and calls /usr/local/sbin/update_cron, which merges the
  entries into root's crontab and HUPs crond.
- Restic binary is now cached on the USB stick at
  /boot/config/plugins/restic-backup/restic.bin during install and
  after every Self-Update. On boot, the rc.d script restores the
  binary from that cache if /usr/local/bin/restic is missing — so a
  reboot without internet no longer leaves the server without restic.
- Self-Update replaces the binary in /usr/local/bin AND refreshes the
  cached copy on the USB stick, so the new version survives the next
  reboot.

## Version 2026.04.18.09
- Fix SFTP (and other non-local) repository URL handling in the target
  editor: the Test and Init Repo buttons were only sending the input
  value to the backend, ignoring the fixed prefix span (sftp://, s3:,
  b2:, rest:, rclone:). This caused "Fatal: parsing repository
  location failed: invalid backend" for a freshly added SFTP target
  unless the user manually typed sftp:// into the input — which then
  caused Save to double the prefix, so the stored URL became
  sftp://sftp://host/path and the Snapshot Browser showed a doubled
  sftp:// in URLs.
- Target URL is now always built as (prefix span) + (bare input value).
  User-typed prefixes are stripped on type change AND on Test / Init,
  so doubled prefixes can no longer be produced.
- Legacy configs with doubled prefixes are auto-healed on load and on
  save: any sftp://sftp://, s3:s3:, etc. is collapsed back to a single
  prefix transparently — no manual re-entry required.

## Version 2026.04.18.08
- Fix plugin upgrade failure: "SHA256SUMS download failure: Network
  failure" from Unraid's plugin manager, which aborted the whole
  upgrade even though the plugin package itself had already been
  downloaded. GitHub's release-asset URLs redirect to a separate CDN
  host (release-assets.githubusercontent.com), which the plugin
  manager's built-in downloader handled unreliably.
- Restic binary + SHA256SUMS are now downloaded by an inline curl
  step during install (with -fL, --retry 3, --connect-timeout 20)
  instead of via Unraid's plugin-file URL mechanism. The curl errors
  are non-fatal, so a transient network issue no longer blocks the
  plugin upgrade — the plugin keeps using the previously installed
  restic binary, and you can always re-run the upgrade or use
  Repository Tools -> Self-Update from the WebUI to refresh it.
- If the same restic version is already installed, the download is
  skipped entirely — re-running the plugin install is now idempotent
  and offline-safe.

## Version 2026.04.18.07
- Snapshot browser: removed the Add Tag / Remove Tag / Set Tags buttons
  from the action bar. The underlying API endpoint and JS helper stay
  (can be re-enabled later), but the UI is now just Diff / Forget /
  Forget + Prune / Rewrite.
- Integrity Check: fixed false "Finished with errors" status — the
  success line "no errors were found" was being matched by the error
  regex. The check output is now stripped of that success phrase
  before the error detection runs.
- Repository Tools: removed the "Copy Entire Repo" section. A full
  repo mirror is better expressed as a per-target option during the
  actual backup run (coming in a later release); the one-shot "copy
  all snapshots" button was confusing and is gone for now. The
  `snapshot_copy` API endpoint itself is retained for a future
  reintroduction.

## Version 2026.04.18.06
- Bundled restic upgraded from 0.17.3 to 0.18.1 (upstream stable).
  Download URL and SHA256SUMS are both driven by the same `resticVer`
  entity in the .plg, so integrity verification of the new binary is
  automatic during install.
- Fix (critical): the Python runner crashed with
  `CRITICAL: name 'job_id' is not defined` right before the first
  target upload, aborting every backup. The live-progress refactor
  added a `job_id` kwarg to `run_backup_attempt()` but forgot to
  expose the variable inside `run_job()`. Backups now run end-to-end
  again and the progress file `/tmp/restic-progress-[jobid].json` is
  written as intended.
- Repository Tools — Check and Recover are now visible: a new
  `repo_tool_log` API tails the background restic log file
  (restricted to `restic-check-*` / `restic-recover-*` /
  `restic-copy-*` inside the plugin log dir) and the WebUI polls
  every 2 s, showing the live output in a scrollable box under each
  action. Polling auto-stops when the command finishes, or can be
  stopped manually with the "Stop polling" button.
- Copy Entire Repo: new dedicated "Copy Entire Repo" panel in
  Repository Tools mirrors ALL snapshots of the selected source
  repository into another target — across different jobs, too. Uses
  `restic copy` with `--repo2` plus the existing `RESTIC_PASSWORD2` /
  `*_2` env-renaming logic. Output streams into the same live log
  viewer as check/recover.
  * The old per-snapshot "Copy to Target" button in the snapshot
    action bar has been removed — repo-level copy is the clearer
    workflow.
  * Note on excludes: `restic copy` cannot apply file-level excludes;
    it works on snapshot granularity (packs are deduplicated as-is).
    For a filtered mirror, configure a second target with its own
    Optional Excludes.

## Version 2026.04.18.04
- Bandwidth Limits per Target: each target now has optional upload and
  download rate caps (KiB/s). The limits are passed to restic as
  `--limit-upload` / `--limit-download` on every operation that talks to
  that target (backup, prune, snapshots, find, ls, restore, stats, check,
  diff, tag, forget, rewrite, copy). Leave blank for unlimited.
- Repository Tools: new "Repository Tools" panel below the snapshot
  browser exposes maintenance actions that previously required SSH:
  * **Unlock** — remove stale locks left by a crashed or killed restic
    process.
  * **Stats** — repository size, snapshot count, deduplicated size,
    per-blob stats.
  * **Check** — integrity check of pack files and indexes.
  * **Recover** — rebuild index from pack files after corruption or a
    missing index.
  * **Restic Self-Update** — update the bundled restic binary in place,
    with SHA256 verification against the upstream `SHA256SUMS` file.
- Snapshot Operations: multi-select checkboxes in the snapshot browser
  unlock bulk actions directly from the WebUI:
  * **Diff** — compare two selected snapshots, showing added / modified
    / removed paths.
  * **Tag** — add or remove tags on one or more snapshots.
  * **Forget** — delete selected snapshots (prompts for confirmation).
  * **Rewrite** — re-write selected snapshots, e.g. to exclude paths
    that should never have been backed up.
  * **Copy** — copy selected snapshots to another target repository
    (uses `--repo2` + `RESTIC_PASSWORD2`, with automatic env renaming
    for SFTP/S3/B2/etc. credentials).
- Live Backup Progress: the Status and Control panel now shows a live
  progress bar during a running backup. The Python runner streams
  restic's `--json` progress output and writes throttled snapshots to
  `/tmp/restic-progress-[jobid].json`. The UI polls that file and
  renders target name, bytes / files done vs. total, percent complete,
  current file, and ETA.
- Restore Verification: a new per-job "Restore Verify" option picks a
  single file that must round-trip cleanly after every backup. After
  a successful upload, the runner hashes the live source with SHA256,
  restores the same path from the `latest` snapshot into a tmpdir,
  hashes the restored copy, and compares. A mismatch marks the target
  as failed so you notice silent corruption immediately.
- Safety hardening:
  * Hooks, job configs, and target credentials are now written via
    atomic tmp+rename+fsync with `chmod 0600` to prevent partial
    writes and leaking of repo passwords / SFTP keys.
  * All hook wrapper scripts run with `set -eo pipefail` so a failed
    command inside a pipeline propagates instead of silently
    succeeding.
  * `restic` binary downloads are verified against the upstream
    `SHA256SUMS` file published by the restic project.
- Bug fixes:
  * First-time hook save no longer emits
    `file_get_contents(...): Failed to open stream: No such file or
    directory` — the writer now checks for existence before reading.
  * PHP 8+ `@` suppression operator: the custom error handler used to
    compare `error_reporting() === 0`, which is no longer accurate
    under PHP 8 where `@` leaves `error_reporting()` unchanged but
    sets a specific bit. Changed to a bitmask check so `@`-suppressed
    warnings are properly silenced across the codebase.

## Version 2026.04.18.03
- Pre/Post-Backup Hooks: new job section for shell commands that run around
  the backup.
  * Pre-hooks run as the very first thing in the job, before ZFS snapshots,
    before path collection, before restic. If a pre-hook with `on_error=abort`
    fails, the backup is skipped entirely.
  * Post-hooks run after all targets are processed, regardless of success or
    failure, and receive `RESTIC_STATUS` (success/partial/failed) plus
    `RESTIC_OK_COUNT` / `RESTIC_FAIL_COUNT` as environment variables.
  * Every hook also gets `RESTIC_JOB_ID`, `RESTIC_JOB_NAME`, `RESTIC_PHASE`,
    `RESTIC_HOSTNAME`.
  * Configurable per hook: name, command (multi-line), enabled toggle,
    timeout (5 s – 24 h), on-error behaviour.
  * Hook commands are materialised as real `.sh` files under
    `/boot/config/plugins/restic-backup/hooks/[jobid]/{pre,post}-[idx]-[slug].sh`
    on save — inspectable via SSH and survives reboot. Stale files are
    pruned automatically when hooks are removed or renamed.
  * Hook stdout/stderr is streamed into the per-job log, so you can verify
    that a DB dump actually ran.

## Version 2026.04.18.02
- Per-job log filtering: each job now writes its own log file
  (`restic-backup-[jobId]-YYYYMMDD.log`) in addition to the combined main
  log, and the log viewer's job selector filters the shown output — pick
  Job A to see only Job A, pick "All Jobs" for the combined stream.
- Cron serialization via `flock`: jobs scheduled at the same minute no
  longer collide on the PID lock. Each cron entry is wrapped in
  `flock -w 21600 /tmp/restic-backup.queue`, so if Job A is still running
  when Job B's cron fires, Job B waits (up to 6h) and runs afterwards.
- Source Label field removed: the per-source label became obsolete with
  original-path backups (restic now records the real mountpoint) and has
  been dropped from the Source Directories editor and the saved config.
- Find files across snapshots: new search panel below the snapshot list
  runs `restic find` against the repo, groups hits by snapshot, and each
  hit has an "Open" button that jumps to the snapshot browser at the
  containing directory so the file can be restored in one click.
  Supports glob patterns, case-insensitive matching, and newest-N
  filtering (7d/30d/90d/1y).

## Version 2026.04.18.01
- Original source paths: restic now records real mountpoints (e.g.
  `/mnt/cache/appdata`) instead of staging paths like `/tmp/.../appdata`.
  * Direct sources are passed as absolute paths — no bind-mount staging.
  * ZFS snapshots are staged under `/tmp/restic-stage/[idx]` and then
    re-bound over their original mountpoint inside an `unshare -m` mount
    namespace so that restic sees the original path.
- File/folder picker: the password-file input now opens a file browser
  (files + folders) instead of directories only. Single click on a file
  highlights it, double click picks it and closes the picker. Quick
  buttons for `/mnt/` and `/boot/` root shortcuts.
- Password-file placeholder no longer pre-suggests "password.txt".
- Manual-run job selector hooked up to the Start button so "Start Backup"
  runs only the selected job ("All Jobs" still runs every enabled job).
- Snapshot list: now scrolls inside a 420px-high container with sticky
  header so many snapshots stay navigable without eating the whole page.
- Responsive design: new breakpoints at 768px and 480px — on phones the
  grid becomes single-column, labels stack above inputs, retention grid
  collapses, unneeded snapshot-table columns are hidden.
- build.sh: MD5 fallback to `md5sum` on Linux.

## Version 2026.04.12.03
- Add per-type credential fields: S3 (Access Key, Secret, Region),
  B2 (Account ID, Application Key), REST (Username, Password)
- SFTP and Rclone show info hint instead (no credentials needed in plugin)
- Auto-prefix URL when type changes (sftp://, s3:, b2:, rest:, rclone:)
- REST credentials injected into URL at backup/test/init time
- S3/B2 credentials passed as environment variables to restic
- Credential fields hidden/shown dynamically when target type is changed

## Version 2026.04.12.02
- Fix file browser appearing for non-local target types (SFTP, S3, etc.)
- Fix save error "unlink: No such file or directory" — error handler now
  respects @ suppression operator (error_reporting() === 0 check)

## Version 2026.04.12.01
- Restructure: package-based install (txz), date-based versioning (YYYY.MM.DD.NN)
- Fix empty API responses: add CSRF token to all AJAX requests (required by Unraid emhttpd)
- Fix output buffering in API: ob_end_clean() + error/shutdown handlers
- Add setup_cron.sh: restores cron jobs from JSON config on every boot via rc.d
- PLG moved to src/, root restic-backup.plg removed

## Version 2025.04.05b
- Initial release
- Restic backup with GUI configuration
- Multiple backup targets support
- ZFS snapshot support (optional, recursive)
- Configurable source directories
- Exclude patterns (global + optional per target)
- Scheduled backups via cron
- Live log viewer
</CHANGES>

<!-- Create required directories -->
<FILE Run="/bin/bash">
<INLINE>
mkdir -p &configDir;
mkdir -p &configDir;/hooks
mkdir -p &tmpDir;
</INLINE>
</FILE>

<!-- Install plugin package -->
<FILE Name="&configDir;/&name;-&version;-x86_64-1.txz" Run="upgradepkg --install-new">
<URL>&pkgURL;/&name;-&version;-x86_64-1.txz</URL>
<MD5>&md5;</MD5>
</FILE>

<!-- Remove old package versions -->
<FILE Run="/bin/bash">
<INLINE>
rm -f $(ls &configDir;/&name;-*.txz 2>/dev/null | grep -v '&version;')
</INLINE>
</FILE>

<!-- Install/refresh restic binary — downloaded inline so that transient
     network issues (e.g. github.com release CDN redirects) don't abort
     the plugin upgrade itself. The plugin can still be used with the
     previously installed restic binary if the download fails.

     The installed binary is ALSO cached on the USB stick at
     &configDir;/restic.bin so that a reboot without internet can restore
     /usr/local/bin/restic via the rc.d script. -->
<FILE Run="/bin/bash">
<INLINE>
# NOTE: intentionally no `set -e` — we want the plugin install to succeed
# even if restic can't be downloaded right now (user can re-run or use
# Self-Update from the WebUI later).

FNAME="restic_&resticVer;_linux_amd64.bz2"
BIN_URL="&resticURL;"
SUMS_URL="&resticSumsURL;"
TMP_BZ="/tmp/restic.bz2"
TMP_SUMS="/tmp/restic.SHA256SUMS"
CACHE_DIR="&configDir;"
CACHE_BIN="$CACHE_DIR/restic.bin"
CACHE_VER="$CACHE_DIR/restic.version"

need_install=1

# If /usr/local/bin/restic is missing but we have a cached copy on the
# USB stick (e.g. after a reboot of tmpfs root), restore it first — this
# keeps the binary available even without internet access.
if [ ! -x /usr/local/bin/restic ] &amp;&amp; [ -s "$CACHE_BIN" ]; then
    echo "Restoring restic from USB cache ($CACHE_BIN)..."
    install -m 0755 "$CACHE_BIN" /usr/local/bin/restic 2>/dev/null || cp -f "$CACHE_BIN" /usr/local/bin/restic
    chmod 755 /usr/local/bin/restic 2>/dev/null
fi

if [ -x /usr/local/bin/restic ]; then
    INSTALLED=$(/usr/local/bin/restic version 2>/dev/null | awk '/^restic/ {print $2}')
    if [ "$INSTALLED" = "&resticVer;" ]; then
        echo "restic &resticVer; already installed — skipping download."
        need_install=0
    fi
fi

if [ "$need_install" = "1" ]; then
    echo "Downloading restic &resticVer; from GitHub..."
    rm -f "$TMP_BZ" "$TMP_SUMS"
    curl -fL --retry 3 --retry-delay 2 --connect-timeout 20 -o "$TMP_BZ"   "$BIN_URL"  || echo "WARNING: restic binary download failed"
    curl -fL --retry 3 --retry-delay 2 --connect-timeout 20 -o "$TMP_SUMS" "$SUMS_URL" || echo "WARNING: SHA256SUMS download failed"

    if [ -f "$TMP_BZ" ] &amp;&amp; [ -s "$TMP_BZ" ]; then
        verified=0
        if [ -f "$TMP_SUMS" ] &amp;&amp; [ -s "$TMP_SUMS" ]; then
            EXPECTED=$(awk -v f="$FNAME" '$2==f {print $1}' "$TMP_SUMS")
            if [ -n "$EXPECTED" ]; then
                ACTUAL=$(sha256sum "$TMP_BZ" | awk '{print $1}')
                if [ "$EXPECTED" = "$ACTUAL" ]; then
                    echo "restic SHA256 verified: $ACTUAL"
                    verified=1
                else
                    echo "ERROR: restic SHA256 mismatch! expected=$EXPECTED actual=$ACTUAL"
                    rm -f "$TMP_BZ" "$TMP_SUMS"
                fi
            else
                echo "WARNING: $FNAME not in SHA256SUMS — installing without verification"
                verified=1
            fi
        else
            echo "WARNING: SHA256SUMS file missing — installing without verification"
            verified=1
        fi

        if [ "$verified" = "1" ] &amp;&amp; [ -f "$TMP_BZ" ]; then
            bunzip2 -f "$TMP_BZ"
            mv /tmp/restic /usr/local/bin/restic
            chmod 755 /usr/local/bin/restic
            echo "Restic installed: $(/usr/local/bin/restic version 2>/dev/null || echo unknown)"

            # Cache a copy on the USB stick so the next reboot can
            # restore it without needing internet access.
            mkdir -p "$CACHE_DIR"
            cp -f /usr/local/bin/restic "$CACHE_BIN" &amp;&amp; chmod 0644 "$CACHE_BIN"
            echo "&resticVer;" > "$CACHE_VER"
            echo "Cached restic binary on USB: $CACHE_BIN"
        fi
    else
        echo "WARNING: restic download skipped — plugin will use previously installed restic (if any)."
        echo "         You can run 'Repository Tools -> Self-Update' from the WebUI later."
    fi

    rm -f "$TMP_SUMS"
fi

# Defensive: if we have /usr/local/bin/restic now but no cache yet (e.g.
# upgrade path from an earlier plugin version), seed the cache.
if [ -x /usr/local/bin/restic ] &amp;&amp; [ ! -s "$CACHE_BIN" ]; then
    mkdir -p "$CACHE_DIR"
    cp -f /usr/local/bin/restic "$CACHE_BIN" &amp;&amp; chmod 0644 "$CACHE_BIN"
    /usr/local/bin/restic version 2>/dev/null | awk '/^restic/ {print $2}' > "$CACHE_VER"
    echo "Seeded USB cache from existing /usr/local/bin/restic."
fi

exit 0
</INLINE>
</FILE>

<!-- rc.d script: on every boot, restore restic from USB cache (tmpfs root
     means /usr/local/bin gets wiped on reboot if not seeded from a
     persistent source), then reinstate cron jobs. -->
<FILE Name="/etc/rc.d/rc.&name;" Mode="755">
<INLINE>
#!/bin/bash
mkdir -p &tmpDir;

# Restore restic binary from USB cache if it's missing (tmpfs rootfs).
CACHE_BIN="&configDir;/restic.bin"
if [ ! -x /usr/local/bin/restic ] &amp;&amp; [ -s "$CACHE_BIN" ]; then
    cp -f "$CACHE_BIN" /usr/local/bin/restic &amp;&amp; chmod 0755 /usr/local/bin/restic \
        &amp;&amp; echo "restic restored from USB cache on boot" &gt;&gt; &tmpDir;/setup_cron.log
fi

&pluginDir;/scripts/setup_cron.sh &gt;&gt;&tmpDir;/setup_cron.log 2&gt;&amp;1
</INLINE>
</FILE>

<!-- Apply cron on install/update -->
<FILE Run="/bin/bash">
<INLINE>
/etc/rc.d/rc.&name;
</INLINE>
</FILE>

<!-- Uninstall -->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
# Stop running backup
if [ -f /tmp/restic-backup.pid ]; then
    PID=$(cat /tmp/restic-backup.pid)
    if [ -d "/proc/${PID}" ]; then
        kill "${PID}" 2>/dev/null
        sleep 1
        kill -9 "${PID}" 2>/dev/null
    fi
    rm -f /tmp/restic-backup.pid
    rm -f /tmp/restic-backup.lock
fi
rm -f &configDir;/&name;.cron
rm -f /etc/rc.d/rc.&name;
# Rebuild root crontab without our entries.
[ -x /usr/local/sbin/update_cron ] &amp;&amp; /usr/local/sbin/update_cron
removepkg &name; 2>/dev/null || rm -rf &pluginDir;
rm -rf &tmpDir;
echo "Restic Backup removed. Settings in &configDir; preserved."
</INLINE>
</FILE>

</PLUGIN>
